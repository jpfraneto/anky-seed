{
  "name": "@anky/backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch server.ts",
    "start": "bun run server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prompt:sample": "bun run eval/scripts/sampleHistoricalAnkys.ts",
