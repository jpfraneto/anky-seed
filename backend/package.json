    "prompt:compare": "bun run eval/scripts/comparePromptRuns.ts",
    "prompt:report": "bun run eval/scripts/writeEvalReport.ts",
    "prompt:lint": "bun run eval/scripts/lintReflection.ts",
    "prompt:judge": "bun run eval/scripts/judgeReflection.ts",
    "prompt:evolve": "bun run eval/scripts/evolvePrompts.ts",
    "prompt:reconcile": "bun run eval/scripts/reconcileTournamentArtifacts.ts",
    "prompt:private-taste": "bun run eval/scripts/privateTasteGate.ts"
  },
  "dependencies": {
    "@anky/protocol": "file:../protocol/implementations/typescript",
    "hono": "^4.12.28",
    "sharp": "^0.35.3",
    "viem": "^2.55.0"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
