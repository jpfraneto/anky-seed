# Anky backend — canonical environment (post-RevenueCat migration).
# RevenueCat webhooks are the sole subscription-entitlement truth.
# Obsolete and intentionally absent: REVENUECAT_PROJECT_ID, REVENUECAT_CREDIT_CODE,
# STRIPE_SECRET_KEY, APPLE_DEVICECHECK_TEAM_ID / _KEY_ID / _PRIVATE_KEY.

# --- reflection (required) ----------------------------------------------------
OPENROUTER_API_KEY=            # OpenRouter API key; without it /anky uses the no-charge fallback
OPENROUTER_MODEL=              # optional; standalone reflection helper model override (default anthropic/claude-sonnet-4.6)
OPENROUTER_TIMEOUT_MS=         # optional; standalone reflection helper timeout in ms (default 45000)

# --- operations ----------------------------------------------------------------
ANKY_ADMIN_KEY=                # bearer key for /debug/* operator routes; unset disables them
ANKY_DATA_DIR=                 # optional; writable dir for the sqlite ledger + paintings (default /data)

# --- RevenueCat (subscription entitlement truth) --------------------------------
REVENUECAT_SECRET_KEY=         # RevenueCat secret API key (sk_...); powers the live REST entitlement fallback
REVENUECAT_WEBHOOK_AUTH=       # exact Authorization header value RevenueCat sends to POST /webhooks/revenuecat

# --- painting pipeline -----------------------------------------------------------
PAINTING_PRIMARY_PROVIDER=     # optional; "openrouter" or "poiesis" (default poiesis)
PAINTING_MODEL=                # optional; primary OpenRouter image model (default openai/gpt-image-2)
PAINTING_FALLBACK_MODEL=       # optional; fallback OpenRouter image model (default openai/gpt-image-1)
PAINTING_DISTILL_MODEL=        # optional; distillation model (default anthropic/claude-sonnet-4.6)
PAINTING_DISTILL_MAX_TOKENS=   # optional; distillation token cap (default 500)
POIESIS_IMAGE_URL=             # poiesis image endpoint; empty disables the poiesis provider
POIESIS_IMAGE_API_KEY=         # poiesis image API key
PAINTING_MAX_POIESIS_QUEUE=    # optional; max queued poiesis jobs (default 8)
PAINTING_MAX_POIESIS_WAIT_MS=  # optional; max poiesis wait in ms (default 480000)
PAINTING_POIESIS_UNDERDRAWING= # optional; "model" to let poiesis draw underdrawings (default programmatic)
PAINTING_OPENROUTER_UNDERDRAWING= # optional; "programmatic" to skip model underdrawings (default model)
PAINTING_MAX_PER_DAY=          # optional; pipeline runs per account per day (default 3)
PAINTING_SPEND_ALERT_USD=      # optional; daily OpenRouter spend alert threshold (default 25)
PAINTING_MAX_DISTILL_CHARS=    # optional; distillation input cap (default 60000)
PAINTING_TIMEOUT_MS=           # optional; per-request painting timeout in ms (default 180000)

# --- eval scripts (dev only, never read by the server) ---------------------------
ANKY_EVAL_MAX_SPEND_USD=       # optional; budget cap for eval/scripts runs
ANKY_EVAL_MAX_CASES=           # optional; case cap for eval/scripts runs
ANKY_EVAL_MODEL=               # optional; candidate model for prompt evals
ANKY_JUDGE_MODEL=              # optional; judge model for prompt evals
