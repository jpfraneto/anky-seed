# Only private material belongs here. Public protocol values live at the top of backend/server.ts.
OPENROUTER_API_KEY=
REVENUECAT_SECRET_KEY=
REVENUECAT_PROJECT_ID=
APPLE_DEVICECHECK_TEAM_ID=
APPLE_DEVICECHECK_KEY_ID=
APPLE_DEVICECHECK_PRIVATE_KEY=
STRIPE_SECRET_KEY=

# Operator-only surface. When unset, /debug/* routes answer 404 for everyone.
ANKY_ADMIN_KEY=

# Painting pipeline (all optional — code defaults in backend/painting/config.ts).
# Production values chosen 2026-07: openrouter primary (GPU lane not ready),
# gpt-image-2 with gpt-image-1 fallback, 3 generations/account/day, $15/day
# spend tripwire. POIESIS_* stay unset until the GPU lane exists; the router
# degrades cleanly to OpenRouter-only without them.
PAINTING_PRIMARY_PROVIDER=openrouter
PAINTING_MODEL=openai/gpt-image-2
PAINTING_FALLBACK_MODEL=openai/gpt-image-1
PAINTING_DISTILL_MODEL=anthropic/claude-sonnet-4.6
PAINTING_MAX_PER_DAY=3
PAINTING_SPEND_ALERT_USD=15
#POIESIS_IMAGE_URL=
#POIESIS_IMAGE_API_KEY=
