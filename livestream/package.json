{
  "name": "anky-live-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'trap \"kill 0\" EXIT; bun run dev:api & bun run dev:overlay & wait'",
    "dev:overlay": "vite --host 0.0.0.0",
    "dev:api": "bun --watch src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "typescript": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
